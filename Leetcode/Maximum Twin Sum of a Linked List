import java.util.*;
class Solution {
    public int pairSum(ListNode head) {
        
        ListNode slow = head;
        ListNode fast = head;
        
        while (fast != null && fast.next != null) {
            slow = slow.next;
            fast = fast.next.next;
        }
        
        ListNode prev = null;
        while (slow != null) {
            ListNode next = slow.next;
            slow.next = prev;
            prev = slow;
            slow = next;
        }
        
        int maxSum = 0;
        ListNode first = head;
        ListNode second = prev;
        
        while (second != null) {
            int sum = first.val + second.val;
            maxSum = Math.max(maxSum, sum);
            
            first = first.next;
            second = second.next;
        }
        
        return maxSum;
    }
}
