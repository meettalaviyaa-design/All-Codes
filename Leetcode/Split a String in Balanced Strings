class Solution {
    public int balancedStringSplit(String s) {
        int count=0;
		 	
		 	int lcount=0;
		 	int rcount=0;
		 	
		 	int maincount=0;
		 	
		 	for(int i=0;i<s.length();i++) {
		 		if(s.charAt(i)=='L') {
		 			lcount++;
		 		}
		 		else {
		 			rcount++;
		 		}
		 		
		 		if(lcount==rcount) {
		 			maincount++;
		 		}
		 	}
		 	return maincount;
    }
}
