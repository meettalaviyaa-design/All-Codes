class Solution {
    public int[] twoSum(int[] numbers, int target) {
        int sum=0;
		
		int i=0;
		int j=numbers.length-1;

        int array[]=new int[2];
		
		while(i<j) {
			sum=numbers[i]+numbers[j];
			
			if(sum==target) {
				int first=i+1;
				int sec=j+1;
				array[0]=first;
				array[1]=sec;
				return array;
			}
			
			if(sum>target) {
				j--;
			}
			else {
				i++;
			}
			
		}
		 return array;
    }
}
