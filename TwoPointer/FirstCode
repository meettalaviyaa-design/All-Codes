int array[]= {1,2,3};
		 int k=3;
		 
		 int sum=0;
		 int count=0;
		 for(int i=0,j=0;j<array.length;j++) {
			 sum+=array[j]; // count sum for subarray 
			 
			 while(sum>k) { check sum bigger then k 
				 sum-=array[i]; // shrink the window from left 
				 i++; //  then i++ 
			 }
			 count+=(j-i+1);  // final count the subarray 
		 }
		 System.out.println(count);
