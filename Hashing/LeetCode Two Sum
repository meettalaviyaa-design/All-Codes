import java.util.*;

class Solution {
    public int[] twoSum(int[] nums, int target) {

        ArrayList<Integer> al=new ArrayList<>(); // this is for store otput beacuse return in int
        HashMap<Integer,Integer> hs=new HashMap<>(); store nums[i],i (value + index store )
        
        for(int i=0;i<nums.length;i++){
            if(hs.containsKey(target-nums[i])){
                al.add(hs.get(target-nums[i]));
                al.add(i);
            }
            hs.put(nums[i],i); // every time store value and their index 
         }
        int[] arr = new int[2];  convert Arraylist to array bcz return type is array 
        for (int i = 0; i < al.size(); i++) {
            arr[i] = al.get(i);
        }
        return arr; return array
    }      
}
