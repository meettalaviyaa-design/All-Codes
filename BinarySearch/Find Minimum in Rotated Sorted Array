class Solution {
    public int findMin(int[] productPrices) {
       
		 int start=0;
		 int end=productPrices.length-1;
		 int min=Integer.MAX_VALUE;
		 while(end>=start) {
			 
			 int mid=start+(end-start)/2;
			 
			 if(productPrices[mid]>=productPrices[end]) {
				 start=mid+1;
			 }
			 else {
				 end=mid-1;
			 }
			 
			 if(productPrices[mid]<min) {
				 min=productPrices[mid];
			 }
		 }
    return min;
    }

}
