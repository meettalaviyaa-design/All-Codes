class Solution {
    public int nthRoot(int n, int m) {
        int start=1;
        int end=m;
        
		 if(m==0) return m;
		 while(end>=start) {
			 int mid=(start+end)/2;
			 
			 if((Math.pow(mid, n))==m) {
				//  System.out.println(mid);
				 return mid;
			 }
			 if((Math.pow(mid, n))>m) {
				 end=mid-1;
			 }
			 else {
				 start=mid+1;
			 }
			 
			 if(start>end) {
				//  System.out.println(-1);
				 return -1;
			 }
			 
		 }
        return -1;
    }
}
